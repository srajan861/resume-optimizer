# Resume Optimizer - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ═══════════════════════════════════════════════════════════════════════════
# SUPABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# Get these from: Supabase Dashboard → Settings → API

# Supabase Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase Service Role Key (Backend only - NEVER expose to frontend)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Supabase JWT Secret (for validating JWT tokens)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Supabase Storage Bucket Name
SUPABASE_BUCKET=resumes

# Supabase Anon/Public Key (Frontend only - safe to expose)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ═══════════════════════════════════════════════════════════════════════════
# GROQ API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# Get your API key from: https://console.groq.com/keys

GROQ_API_KEY=your-groq-api-key-here

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# CORS Allowed Origins (JSON array format)
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Maximum file upload size (in MB)
MAX_FILE_SIZE_MB=10

# Require email verification for authentication
REQUIRE_EMAIL_VERIFICATION=false

# Debug mode (set to false in production)
DEBUG=true

# ═══════════════════════════════════════════════════════════════════════════
# FRONTEND CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# API Base URL (where backend is running)
VITE_API_URL=http://localhost:8000

# Supabase URL for frontend (same as SUPABASE_URL)
VITE_SUPABASE_URL=https://your-project.supabase.co

# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION OVERRIDES (uncomment for production deployment)
# ═══════════════════════════════════════════════════════════════════════════

# DEBUG=false
# REQUIRE_EMAIL_VERIFICATION=true
# ALLOWED_ORIGINS=["https://yourdomain.com"]
# VITE_API_URL=https://api.yourdomain.com
